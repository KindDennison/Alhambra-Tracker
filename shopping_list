<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shopping List</title>
  <script src="https://www.gstatic.com/firebasejs/10.5.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.5.0/firebase-firestore-compat.js"></script>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      margin: 0;
      padding: 1rem;
    }
    .container {
      max-width: 800px;
      margin: 20px auto;
      background: white;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    h1 {
      text-align: center;
      color: #0055a5;
      margin-bottom: 20px;
    }
    form label {
      display: block;
      margin-bottom: 5px;
      font-weight: bold;
    }
    form input[type="text"],
    form select {
      width: calc(100% - 22px);
      padding: 10px;
      margin-bottom: 15px;
      border: 1px solid #ddd;
      border-radius: 4px;
    }
    form button {
      width: 100%;
      padding: 10px;
      background: #0055a5;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
    }
    form button:hover {
      background: #003f7f;
    }
    #shoppingListDisplay {
      margin-top: 30px;
      border-top: 1px solid #eee;
      padding-top: 20px;
    }
    .item-card {
      background: #f9f9f9;
      border: 1px solid #eee;
      padding: 10px 15px;
      margin-bottom: 10px;
      border-radius: 5px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .item-card.purchased {
        background: #e6ffe6; /* Light green for purchased items */
        text-decoration: line-through;
        color: #666;
    }
    .item-card button {
        width: auto;
        padding: 5px 10px;
        margin-left: 10px;
        font-size: 0.8rem;
    }
    .item-card .actions {
        display: flex;
        gap: 5px;
    }
    .item-card .delete-button {
        background-color: #dc3545; /* Red for delete */
    }
    .item-card .delete-button:hover {
        background-color: #c82333;
    }
    .item-card .purchased-button {
        background-color: #28a745; /* Green for purchased */
    }
    .item-card .purchased-button:hover {
        background-color: #218838;
    }
    .no-items {
        text-align: center;
        color: #666;
        padding: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Shopping List</h1>

    <form id="addItemForm">
      <label for="itemName">Item Name:</label>
      <input type="text" id="itemName" placeholder="e.g., Apples" required />

      <label for="itemIsle">Isle:</label>
      <input type="text" id="itemIsle" placeholder="e.g., 1" required />

      <label for="itemPosition">Position:</label>
      <select id="itemPosition" required>
        <option value="">Select Position</option>
        <option value="Start of Isle">Start of Isle</option>
        <option value="Middle of Isle">Middle of Isle</option>
        <option value="End of Isle">End of Isle</option>
      </select>

      <label for="itemSide">Side:</label>
      <select id="itemSide" required>
        <option value="">Select Side</option>
        <option value="Left">Left</option>
        <option value="Right">Right</option>
        <option value="Both">Both</option>
      </select>

      <button type="submit">Add Item</button>
    </form>

    <div id="shoppingListDisplay">
      <h2>Your List</h2>
      <div id="itemsContainer">
        <!-- Shopping list items will be loaded here -->
        <p class="no-items">No items in your list yet. Add some above!</p>
      </div>
    </div>
  </div>

  <script>
    // Your Firebase config (from index.html and fuel.html)
    const firebaseConfig = {
      apiKey: "AIzaSyDJXVZE2VZXPH9jJvzgz9ozBvvbiJfmLbw",
      authDomain: "teamdennisontracker.firebaseapp.com",
      projectId: "teamdennisontracker",
      storageBucket: "teamdennisontracker.firebasestorage.app",
      messagingSenderId: "915336870349",
      appId: "1:915336870349:web:c070e9b3fc0b688fe62c84"
    };

    // Initialize Firebase
    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore(); // Get a reference to the Firestore database

    const addItemForm = document.getElementById('addItemForm');
    const itemsContainer = document.getElementById('itemsContainer');

    // Function to add a new item
    addItemForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const itemName = document.getElementById('itemName').value;
      const itemIsle = parseInt(document.getElementById('itemIsle').value); // Parse as integer for sorting
      const itemPosition = document.getElementById('itemPosition').value;
      const itemSide = document.getElementById('itemSide').value;

      if (!itemName || isNaN(itemIsle) || !itemPosition || !itemSide) {
        alert('Please fill in all fields correctly.');
        return;
      }

      try {
        await db.collection('shoppingList').add({
          name: itemName,
          isle: itemIsle,
          position: itemPosition,
          side: itemSide,
          purchased: false, // New field to track if purchased
          timestamp: firebase.firestore.FieldValue.serverTimestamp() // To keep track of creation order if needed
        });

        // Clear form fields
        addItemForm.reset();
        document.getElementById('itemName').focus(); // Keep focus on item name for quick entry
      } catch (error) {
        console.error("Error adding document: ", error);
        alert("Failed to add item. Please try again.");
      }
    });

    // Function to render the shopping list
    const renderShoppingList = (items) => {
      itemsContainer.innerHTML = ''; // Clear current list

      if (items.length === 0) {
        itemsContainer.innerHTML = '<p class="no-items">No items in your list yet. Add some above!</p>';
        return;
      }

      // Sort items: first by isle (numeric), then by a custom order for position, then by side
      const positionOrder = {
        "Start of Isle": 1,
        "Middle of Isle": 2,
        "End of Isle": 3
      };

      items.sort((a, b) => {
        // Sort by purchased status (false first, then true)
        if (a.purchased !== b.purchased) {
            return a.purchased - b.purchased;
        }
        // Then by isle
        if (a.isle !== b.isle) {
          return a.isle - b.isle;
        }
        // Then by position
        if (positionOrder[a.position] !== positionOrder[b.position]) {
          return positionOrder[a.position] - positionOrder[b.position];
        }
        // Then by side
        if (a.side !== b.side) {
            return a.side.localeCompare(b.side);
        }
        return 0; // Maintain original order if all above are equal
      });

      items.forEach(item => {
        const itemCard = document.createElement('div');
        itemCard.classList.add('item-card');
        if (item.purchased) {
            itemCard.classList.add('purchased');
        }
        itemCard.innerHTML = `
          <div>
            <strong>${item.name}</strong> <br>
            Isle ${item.isle}, ${item.position}, ${item.side}
          </div>
          <div class="actions">
            <button class="purchased-button" data-id="${item.id}" data-purchased="${item.purchased}">
                ${item.purchased ? 'Unmark' : 'Purchased'}
            </button>
            <button class="delete-button" data-id="${item.id}">Delete</button>
          </div>
        `;
        itemsContainer.appendChild(itemCard);
      });
    };

    // Real-time listener for shopping list changes
    db.collection('shoppingList').orderBy('timestamp', 'asc') // Order by timestamp to maintain initial order when fetched
      .onSnapshot((snapshot) => {
        const items = [];
        snapshot.forEach((doc) => {
          items.push({ id: doc.id, ...doc.data() });
        });
        renderShoppingList(items);
      }, (error) => {
        console.error("Error fetching shopping list: ", error);
      });

    // Event delegation for delete and purchased buttons
    itemsContainer.addEventListener('click', async (e) => {
        if (e.target.classList.contains('delete-button')) {
            const itemId = e.target.dataset.id;
            if (confirm('Are you sure you want to delete this item?')) {
                try {
                    await db.collection('shoppingList').doc(itemId).delete();
                } catch (error) {
                    console.error("Error removing document: ", error);
                    alert("Failed to delete item. Please try again.");
                }
            }
        } else if (e.target.classList.contains('purchased-button')) {
            const itemId = e.target.dataset.id;
            const currentPurchasedStatus = e.target.dataset.purchased === 'true'; // Convert string to boolean
            try {
                await db.collection('shoppingList').doc(itemId).update({
                    purchased: !currentPurchasedStatus // Toggle the status
                });
            } catch (error) {
                console.error("Error updating document: ", error);
                alert("Failed to update item status. Please try again.");
            }
        }
    });

  </script>
</body>
</html>
